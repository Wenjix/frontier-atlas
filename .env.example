# Database
DATABASE_URL=postgresql://user:password@localhost:5432/frontier_atlas

# Auth (NextAuth)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Admin Access
ADMIN_EMAILS=admin@example.com

# Email / SMTP (required for production magic links and onboarding emails)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@frontieratlas.com

# Telegram Mini App (optional)
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_COMMUNITY_INVITE_URL=
