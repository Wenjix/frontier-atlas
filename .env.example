# Database
DATABASE_URL=postgresql://user:password@localhost:5432/frontier_atlas

# Auth (NextAuth)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Admin Access
ADMIN_EMAILS=admin@example.com

# Email / SMTP (required for production magic links and onboarding emails)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@frontieratlas.com

# Telegram Mini App (optional)
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_COMMUNITY_INVITE_URL=

# Web3 — Required for wallet auth
ETHEREUM_RPC_URL=                        # Server-side mainnet RPC (Alchemy/Infura). NEVER prefix with NEXT_PUBLIC_
SELF_APP_ID=                             # Self Protocol developer portal app ID

# Web3 — Optional
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=    # Reown dashboard (safe to expose client-side)
ADMIN_WALLETS=                           # Comma-separated checksummed EIP-55 addresses
SELF_MOCK=true                           # Set to "false" for real Self Protocol verification
